<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinalProjectNoaRippel.Views.AdminPage"
             xmlns:vm="clr-namespace:FinalProjectNoaRippel.ViewModels"
             x:DataType="vm:AdminPageViewModel"
             BackgroundColor="White">
    <VerticalStackLayout Padding="24,40" Spacing="24">

        <Label
            FontAttributes="Bold"
            FontSize="22"
            HorizontalOptions="Center"
            Text="Welcome to Admin Page"
            TextColor="#2C3947" />

        <Button
            BackgroundColor="#9ED3DC"
            Command="{Binding ViewUsersCommand}"
            CornerRadius="8"
            FontSize="17"
            HeightRequest="50"
            HorizontalOptions="Fill"
            Text="View Users"
            TextColor="#1A1A1A" />

    </VerticalStackLayout>
</ContentPage>