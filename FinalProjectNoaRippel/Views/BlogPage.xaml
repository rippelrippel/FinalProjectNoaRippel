<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="FinalProjectNoaRippel.Views.BlogPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:FinalProjectNoaRippel.ViewModels"
    xmlns:helper="clr-namespace:FinalProjectNoaRippel.Helper"
    x:DataType="viewmodels:BlogViewModel"
    Title="Blog"
    BackgroundColor="White">

    <ContentPage.Resources>
        <helper:Base64ToImageConverter x:Key="Base64ToImageConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="16,20" Spacing="12">

                <Label
                    Text="Blog"
                    FontSize="26"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    TextColor="Black" />

                <CollectionView ItemsSource="{Binding BlogRecipes}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="viewmodels:BlogRecipeItem">
                            <Border
                                Margin="0,5"
                                Stroke="#E0E0E0"
                                StrokeShape="RoundRectangle 12"
                                BackgroundColor="#F5F5F5"
                                HeightRequest="140">
                                <Grid ColumnDefinitions="140,*" ColumnSpacing="0">

                                    <!-- תמונה גדולה בצד שמאל -->
                                    <Image
                                        Grid.Column="0"
                                        Aspect="AspectFill"
                                        Source="{Binding ImageSource, Converter={StaticResource Base64ToImageConverter}}"
                                        WidthRequest="140"
                                        HeightRequest="140" />

                                    <!-- טקסט בצד ימין -->
                                    <VerticalStackLayout
                                        Grid.Column="1"
                                        Padding="14,0"
                                        VerticalOptions="Center"
                                        Spacing="6">
                                        <Label
                                            Text="{Binding Name}"
                                            FontSize="18"
                                            FontAttributes="Bold"
                                            TextColor="Black"
                                            LineBreakMode="WordWrap" />
                                        <Label
                                            Text="{Binding AuthorName, StringFormat='By {0}'}"
                                            FontSize="13"
                                            TextColor="Gray" />
                                    </VerticalStackLayout>

                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectRecipeCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <Grid Grid.Row="1" Padding="24,12" BackgroundColor="White">
            <Button
                BackgroundColor="#28396C"
                Command="{Binding AddNewBlogRecipeCommand}"
                Text="+ Add Recipe to Blog"
                TextColor="White" />
        </Grid>
    </Grid>
</ContentPage>
