<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="FinalProjectNoaRippel.Views.CommunityPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:FinalProjectNoaRippel.ViewModels"
    x:DataType="viewmodels:CommunityViewModel"
    Title="קהילה"
    BackgroundColor="White">
    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="16,12" Spacing="10">
                <Label Text="קהילה" FontSize="26" FontAttributes="Bold"
                       HorizontalOptions="Center" TextColor="Black" />
                <BoxView BackgroundColor="#38396C" HeightRequest="2.5" />

                <CollectionView ItemsSource="{Binding Comments}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="viewmodels:CommunityComment">
                            <Border Margin="0,4" Padding="12,8"
                                    BackgroundColor="#F5F5F5"
                                    StrokeShape="RoundRectangle 8"
                                    StrokeThickness="0">
                                <Grid ColumnDefinitions="*,Auto">
                                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                                        <Label Text="{Binding Text}" FontSize="15"
                                               TextColor="Black" HorizontalTextAlignment="End" />
                                        <Label Text="{Binding AuthorName}" FontSize="12"
                                               TextColor="Gray" HorizontalTextAlignment="End" />
                                    </VerticalStackLayout>
                                    <Label Grid.Column="1" Text="&#xE872;" FontFamily="MaterialIcons"
                                           FontSize="20" TextColor="Red" VerticalOptions="Center"
                                           Margin="8,0,0,0" IsVisible="{Binding CanDelete}">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteCommentCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Padding="16,10" BackgroundColor="White">
            <Border Grid.Column="0" Padding="10" Stroke="#ccc"
                    StrokeShape="RoundRectangle 8" StrokeThickness="1">
                <Entry Placeholder="כתוב תגובה..." TextColor="Black"
                       HorizontalTextAlignment="End"
                       Text="{Binding NewCommentText}" />
            </Border>
            <Button Grid.Column="1" Text="שלח" BackgroundColor="#28396C"
                    TextColor="White" CornerRadius="8" Margin="8,0,0,0"
                    Command="{Binding AddCommentCommand}" />
        </Grid>

    </Grid>
</ContentPage>