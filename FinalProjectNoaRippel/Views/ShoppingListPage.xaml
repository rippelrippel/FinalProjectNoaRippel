<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinalProjectNoaRippel.Views.ShoppingListPage"
             xmlns:viewmodels="clr-namespace:FinalProjectNoaRippel.ViewModels"
             x:DataType="viewmodels:ShoppingListViewModel"
             BackgroundColor="White"
             Title="ShoppingListPage">

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="24,20" Spacing="10">

                <Label Text="Shopping List" FontSize="26" FontAttributes="Bold"
                       HorizontalOptions="Center" TextColor="Black" />

                <Border Padding="16" BackgroundColor="#F0F0F0"
                        StrokeShape="RoundRectangle 8" Stroke="Transparent">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Ingredients" FontSize="16"
                               TextColor="#28396C" FontAttributes="Bold" />
                        <CollectionView ItemsSource="{Binding Items}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="viewmodels:ShoppingItem">
                                    <Grid ColumnDefinitions="Auto,*" Padding="0,4">
                                        <Label Text="•" FontSize="16" TextColor="#333"
                                               VerticalOptions="Center" Margin="0,0,8,0" />
                                        <Label Grid.Column="1"
                                               Text="{Binding Text}"
                                               FontSize="16" TextColor="#333"
                                               VerticalOptions="Center">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteItemCommand}"
                                                    CommandParameter="{Binding .}" />
                                            </Label.GestureRecognizers>
                                        </Label>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- edit list button -->
        <Grid Grid.Row="1" Padding="24,12" BackgroundColor="White">
            <Label Text="edit list" FontSize="16" TextColor="Black"
                   HorizontalOptions="End" VerticalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToEditCommand}" />
                </Label.GestureRecognizers>
            </Label>
        </Grid>
    </Grid>
</ContentPage>