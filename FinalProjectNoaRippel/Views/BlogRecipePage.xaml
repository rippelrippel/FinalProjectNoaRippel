<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="FinalProjectNoaRippel.Views.BlogRecipePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:FinalProjectNoaRippel.ViewModels"
    xmlns:helper="clr-namespace:FinalProjectNoaRippel.Helper"
    x:DataType="viewmodels:BlogRecipeViewModel"
    BackgroundColor="White"
    Title="Blog Recipe">
    <ContentPage.Resources>
        <helper:BoolToStrikethroughConverter x:Key="BoolToStrikethroughConverter" />
    </ContentPage.Resources>
    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="24,10" Spacing="10">

                <Label Text="{Binding RecipeName}" FontSize="28" FontAttributes="Bold"
                       HorizontalOptions="Center" TextColor="Black" />
                <Label Text="{Binding AuthorName, StringFormat='By {0}'}"
                       FontSize="14" TextColor="Gray" HorizontalOptions="Center" />
                <Label Text="{Binding CategoryName}" FontSize="13"
                       TextColor="#28396C" FontAttributes="Italic"
                       HorizontalOptions="Center" />
                <BoxView HeightRequest="2" BackgroundColor="Gray" />

                <Grid ColumnDefinitions="Auto,*">
                    <Label Grid.Column="0" FontSize="14" TextColor="#555" VerticalOptions="Center">
                        <Label.Text>
                            <Binding Path="PrepTime" StringFormat="⏱ {0}" />
                        </Label.Text>
                    </Label>
                    <Label Grid.Column="1" Text="מרכיבים" FontSize="20" FontAttributes="Bold"
                           HorizontalTextAlignment="End" TextColor="Black" />
                </Grid>

                <CollectionView ItemsSource="{Binding Ingredients}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="viewmodels:CheckableItem">
                            <Grid ColumnDefinitions="*,Auto" Padding="5">
                                <Label Grid.Column="0" Text="+" FontSize="22" TextColor="#28396C"
                                       VerticalOptions="Center" Margin="0,0,8,0">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.AddToShoppingListCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Label.GestureRecognizers>
                                </Label>
                                <Label Grid.Column="1" Text="{Binding Text}" FontSize="16"
                                       HorizontalTextAlignment="End" VerticalOptions="Center" TextColor="Black" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <BoxView HeightRequest="2" BackgroundColor="Gray" />

                <Label Text="הוראות הכנה" FontSize="20" FontAttributes="Bold"
                       HorizontalTextAlignment="End" TextColor="Black" />
                <CollectionView ItemsSource="{Binding Instructions}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="viewmodels:CheckableItem">
                            <Label Text="{Binding Text}" FontSize="16"
                                   HorizontalTextAlignment="End" TextColor="Black" Margin="0,5" />
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <Grid Grid.Row="1" Padding="24,12" BackgroundColor="White">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Label Grid.Column="0" Text="&#xE872;" FontFamily="MaterialIcons"
        FontSize="28" TextColor="Red" HorizontalOptions="Start" VerticalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding DeleteRecipeCommand}" />
                </Label.GestureRecognizers>
            </Label>

            <Button Grid.Column="1" Text=" תגובות" BackgroundColor="#28396C"
                    TextColor="White" CornerRadius="8" HeightRequest="40" WidthRequest="100"
                    HorizontalOptions="Center"
                    Command="{Binding GoToCommunityCommand}" />

            <Label Grid.Column="2" Text="Edit" FontSize="16" TextColor="Black"
                   HorizontalOptions="End" VerticalOptions="Center"
                   IsVisible="{Binding IsOwner}">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding EditBlogRecipeCommand}" />
                </Label.GestureRecognizers>
            </Label>
        </Grid>
    </Grid>
</ContentPage>