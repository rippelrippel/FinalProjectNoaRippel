<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinalProjectNoaRippel.Views.EditShoppingListPage"
             xmlns:viewmodels="clr-namespace:FinalProjectNoaRippel.ViewModels"
             x:DataType="viewmodels:EditShoppingListViewModel"
             BackgroundColor="White"
             Title="EditShoppingListPage">

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="24,20" Spacing="10">

                <Label Text="Edit Shopping List" FontSize="26" FontAttributes="Bold"
                       HorizontalOptions="Center" TextColor="Black" />

                <Border Padding="16" BackgroundColor="#F0F0F0"
                        StrokeShape="RoundRectangle 8" Stroke="Transparent">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Ingredients" FontSize="16"
                               TextColor="#28396C" FontAttributes="Bold" />

                        <CollectionView ItemsSource="{Binding Items}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="viewmodels:ShoppingItem">
                                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="0,4">
                                        <Label Text="•" FontSize="16" TextColor="#333"
                                               VerticalOptions="Center" Margin="0,0,8,0" />
                                        <Entry Grid.Column="1"
                                               Text="{Binding Text}"
                                               FontSize="16" TextColor="#333" />
                                        <Label Grid.Column="2"
                                               Text="&#xE872;"
                                               FontFamily="MaterialIcons"
                                               FontSize="22" TextColor="Red"
                                               VerticalOptions="Center" Margin="8,0,0,0">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteItemCommand}"
                                                    CommandParameter="{Binding .}" />
                                            </Label.GestureRecognizers>
                                        </Label>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Label Text="+ add ingredient" FontSize="14"
                               TextColor="#28396C" Margin="8,8,0,0">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding AddItemCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <Button Grid.Row="1" Text="save" BackgroundColor="#28396C"
                TextColor="White" Margin="24,12"
                Command="{Binding SaveCommand}" />
    </Grid>
</ContentPage>